# Configuration file for EditorConfig (https://editorconfig.org)

root=true

[*]
charset=utf-8
insert_final_newline=true
max_line_length=80
trim_trailing_whitespace=true

[*.go]
indent_style=tab

[*.md]
indent_size=unset
indent_style=space

[*.txt]
indent_size=unset
indent_style=space
max_line_length=72
